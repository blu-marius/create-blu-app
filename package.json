{
  "name": "create-blu-app",
  "version": "1.0.4",
  "description": "Scaffold a new project with the Blu Stack: Next.js, shadcn, Tailwind CSS, Supabase, TanStack Query, React Hook Form, Zod, React Email, and Resend",
  "type": "module",
  "exports": "./dist/index.mjs",
  "bin": {
    "create-blu-app": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "start": "node dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "create-blu-app",
    "nextjs",
    "shadcn",
    "tailwind",
    "supabase",
    "tanstack-query",
    "react-hook-form",
    "zod",
    "react-email",
    "resend",
    "scaffold",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blu-marius/create-blu-app.git"
  },
  "bugs": {
    "url": "https://github.com/blu-marius/create-blu-app/issues"
  },
  "homepage": "https://github.com/blu-marius/create-blu-app#readme",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsdown": "^0.21.4",
    "typescript": "^5.8.2",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
